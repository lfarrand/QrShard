{
  // QrShard settings. This file is optional: delete a setting (or the whole file) to use the
  // defaults. JSON comments and trailing commas are allowed here — the parser skips them, the
  // same way standard .NET appsettings files do. Invalid values fail loudly at startup rather
  // than silently falling back.
  //
  // Deliberately NOT configurable: anything both sides of a transfer must agree on — frame
  // geometry, metadata-strip layout, magic numbers, Reed-Solomon/GF(2^8) parameters — plus the
  // decoder's detection heuristics. Those are protocol, not preference; a settings file on one
  // machine would silently break decoding on another.

  // ---- Encode defaults (each one is overridden by its CLI flag when given) ----
  "EncodeDefaults": {
    // -r/--resolution: "auto" detects the primary monitor's native resolution so shards fill
    // the screen they'll be captured from (falls back to 2160 when no display is available);
    // or one number (square) or WxH, 700-16384 per side, to override — e.g. a smaller size
    // to show the code surrounded by black padding on the display.
    "Resolution": "auto",
    // -c/--cell: data cell size in pixels, 1-64.
    "CellPx": 3,
    // -b/--bits: bits per cell (color density), 1-8.
    "BitsPerCell": 4,
    // -e/--ecc: Reed-Solomon parity bytes per 255-byte block; even, 0-64.
    "EccParity": 16,
    // -R/--recovery: extra parity images as % of data images, 0-100 (0 = off).
    "RecoveryPercent": 0,
    // -f/--format: png, bmp, tga, qoi, webp, or tiff.
    "ImageFormat": "png",
    // false is the same as always passing --no-compress.
    "Compress": true
  },

  // Folder created next to the input when -o/--out is not given: <file><suffix>.
  "ShardFolderSuffix": ".shards",

  // Deflate level for the built-in PNG writer, applied where compression pays off (cell sizes
  // >= 2 px, where the Up filter makes repeated rows compressible). Images with 1 px cells
  // always use Fastest, because their noise-like content is incompressible by construction.
  //
  // Possible values (System.IO.Compression.CompressionLevel, case-insensitive):
  //   "Optimal"       - default; ~10% smaller shards than Fastest at a modest encode-time cost
  //   "Fastest"       - ~25% quicker encode, ~45% larger shard files
  //   "SmallestSize"  - maximum compression; noticeably slower encode
  //   "NoCompression" - stored (uncompressed) PNGs; huge files, debugging only
  "PngCompressionLevel": "Optimal",

  // Deflate level used when compressing the file payload itself (same possible values).
  // Only consulted when compression is on and the content looks compressible.
  "PayloadCompressionLevel": "Optimal",

  // ---- Machine tuning ----

  // Memory budget (MB) for the encoder's per-worker pixel canvases; caps how many images are
  // rendered in parallel. Lower on memory-constrained machines, raise for 16K resolutions.
  // Range 64-1000000.
  "EncodeMemoryBudgetMB": 2000,

  // Max parallel image decodes. 0 = automatic (number of cores, capped at 16 — PNG decode goes
  // memory-bandwidth-bound beyond that). Range 0-1024.
  "DecodeMaxParallelism": 0
}
